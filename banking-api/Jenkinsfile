pipeline {
    agent any

    environment {
        DOCKERHUB_IMAGE = "giobrancher/banking-api"
        SONAR_SCANNER_HOME = tool 'SonarScanner'
        GITHUB_REPO = "giovanni-brancher/pgats-desafio-ci"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Secret Scan') {
            steps {
                sh '''
                    docker run --rm \
                        -v "$(pwd):/pwd" \
                        trufflesecurity/trufflehog:latest \
                        filesystem /pwd \
                        --only-verified \
                        --fail
                '''
            }
        }

        stage('Install') {
            steps {
                dir('banking-api') {
                    sh '''
                        python3 -m venv .venv
                        . .venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Lint') {
            parallel {
                stage('Python Lint') {
                    steps {
                        dir('banking-api') {
                            sh '''
                                . .venv/bin/activate
                                flake8 app/
                            '''
                        }
                    }
                }
                stage('Dockerfile Lint') {
                    steps {
                        dir('banking-api') {
                            sh '''
                                docker run --rm \
                                    -i hadolint/hadolint \
                                    < Dockerfile
                            '''
                        }
                    }
                }
            }
        }

        stage('Smoke Tests') {
            steps {
                dir('banking-api') {
                    sh '''
                        . .venv/bin/activate
                        pytest -m smoke --cov=app --cov-report=xml --junitxml=smoke-results.xml -v
                    '''
                }
            }
            post {
                always {
                    junit 'banking-api/smoke-results.xml'
                }
            }
        }

        stage('Regression Tests') {
            when {
                anyOf {
                    expression { env.BRANCH_NAME == 'master' }
                    expression { env.GIT_BRANCH == 'origin/master' }
                    triggeredBy 'TimerTrigger'
                    changeRequest target: 'master'
                }
            }
            steps {
                dir('banking-api') {
                    sh '''
                        . .venv/bin/activate
                        pytest -m "smoke or regression" --cov=app --cov-report=xml --junitxml=regression-results.xml -v
                    '''
                }
            }
            post {
                always {
                    junit 'banking-api/regression-results.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('banking-api') {
                    withSonarQubeEnv('SonarQube') {
                        sh "${SONAR_SCANNER_HOME}/bin/sonar-scanner"
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('banking-api') {
                    sh "docker build -t ${DOCKERHUB_IMAGE}:${BUILD_NUMBER} -t ${DOCKERHUB_IMAGE}:latest ."
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ''' + '${DOCKERHUB_IMAGE}:${BUILD_NUMBER}' + '''
                        docker push ''' + '${DOCKERHUB_IMAGE}:latest' + '''
                    '''
                }
            }
        }

        stage('GitHub Release') {
            when {
                anyOf {
                    expression { env.BRANCH_NAME == 'master' }
                    expression { env.GIT_BRANCH == 'origin/master' }
                }
            }
            steps {
                withCredentials([string(credentialsId: 'github-token', variable: 'GH_TOKEN')]) {
                    sh """
                        curl -s -X POST \\
                            -H "Authorization: token \$GH_TOKEN" \\
                            -H "Content-Type: application/json" \\
                            -d '{"tag_name":"v${BUILD_NUMBER}","name":"Release v${BUILD_NUMBER}","body":"Build automático #${BUILD_NUMBER} — imagem Docker: ${DOCKERHUB_IMAGE}:${BUILD_NUMBER}","draft":false,"prerelease":false}' \\
                            https://api.github.com/repos/${GITHUB_REPO}/releases
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('banking-api') {
                    withCredentials([file(credentialsId: 'banking-api-env', variable: 'ENV_FILE')]) {
                        sh '''
                            cp "$ENV_FILE" .env
                            docker compose up -d
                            rm -f .env
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline executada com sucesso!'
        }
        failure {
            echo 'Pipeline falhou. Verifique os logs acima.'
        }
    }
}
